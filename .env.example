# ─── Database ──────────────────────────────────────────────
# SQLite local (zero install). Pour Postgres : postgresql+asyncpg://user:pwd@host:5432/db
DATABASE_URL=sqlite+aiosqlite:///./analyseur.db

# ─── Exchange ──────────────────────────────────────────────
EXCHANGE_ID=binance

# ─── Watchlist ─────────────────────────────────────────────
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAMES=5m,15m,1h,4h,1d
SCAN_INTERVAL_SECONDS=60

# ─── Quality filters (optimisation patterns - voir run_loop.py) ────
# Issus du backtest 14 jours : config qui a donne +14.76% compound, 58.6% win
MIN_CONFLUENCE_SCORE=0.0
MIN_RR_RATIO=0.0
REJECT_TREND_COUNTER=false
REQUIRE_VOLUME_EXPANSION=false
BREAKEVEN_TRIGGER_PCT=0.0

# ─── API ──────────────────────────────────────────────────
API_KEY=changeme

# ─── Telegram bot (optionnel) ─────────────────────────────
# 1. /newbot via @BotFather pour creer le bot et obtenir TELEGRAM_BOT_TOKEN
# 2. Envoie /start au bot une fois lance (start_telegram.bat), le chat_id
#    s'affiche dans la console. Mets-le dans TELEGRAM_ADMIN_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Notifs auto sur events scanner (true/false)
TG_NOTIFY_TRIGGER=true
TG_NOTIFY_CLOSE=true

# URLs locales (pour les liens depuis Telegram)
DASHBOARD_URL=http://127.0.0.1:8000/patterns
API_BASE=http://127.0.0.1:8000/api/v1
